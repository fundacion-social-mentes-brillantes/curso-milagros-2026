# =============================================================
#  Variables de entorno — Curso de Milagros 2026
#  Copia este archivo como  .env.local  y rellena los valores.
#  NUNCA subas .env.local a internet (ya está en .gitignore).
# =============================================================

# --- Firebase (lado del navegador) ---------------------------
# Estas claves son PÚBLICAS (van dentro de la página). La seguridad
# real la dan las reglas de Firestore, no estas claves.
# Las obtienes en: Firebase Console > ⚙️ Configuración del proyecto > Tus apps (web)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Administradores (interfaz) ------------------------------
# Correos que verán el panel admin. La validación REAL está en las reglas
# de Firestore (por correo verificado de Google). Separados por coma.
NEXT_PUBLIC_ADMIN_EMAILS=fundacionsocial@gimnasioemocionalmb.com

# --- Año del curso (opcional) --------------------------------
NEXT_PUBLIC_COURSE_YEAR=2026

# =============================================================
#  NOTA: Esta app NO necesita clave de servidor (service account).
#  Todo funciona con las claves públicas de arriba + las reglas.
#  Las lecciones se crean e importan desde el panel /admin/lecciones.
#
#  (Avanzado/opcional) Si algún día quieres usar los scripts de
#  terminal, necesitarías credenciales de Admin vía Google Cloud
#  (gcloud auth application-default login) o un service account.
# =============================================================
