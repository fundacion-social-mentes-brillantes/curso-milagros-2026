rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Correos que SIEMPRE son admin (edítalos aquí si cambian).
    function adminEmails() {
      return [
        'fundacionsocial@gimnasioemocionalmb.com'
      ];
    }

    // Admin = correo verificado en la lista O rol 'admin' en su doc.
    // No requiere claves de servidor: se valida con el correo del login de Google.
    function isAdmin() {
      return isSignedIn() && (
        (
          request.auth.token.email_verified == true &&
          request.auth.token.email in adminEmails()
        ) ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        )
      );
    }

    // --- USUARIOS ---
    match /users/{uid} {
      // Cada quien lee SOLO su propio perfil; el admin puede listar a todos.
      // (Protege los correos y teléfonos de las demás personas.)
      allow get: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow list: if isAdmin();
      // Cada quien crea su propio perfil y SOLO como 'user'.
      allow create: if isSignedIn()
                    && request.auth.uid == uid
                    && request.resource.data.role == 'user';
      // Puedes editar tu propio perfil, pero NO tu rol. El admin sí puede.
      allow update: if isAdmin()
                    || (isSignedIn()
                        && request.auth.uid == uid
                        && request.resource.data.role == resource.data.role
                        && request.resource.data.enrolled == resource.data.enrolled);
      allow delete: if isAdmin();
    }

    // --- LECCIONES ---
    match /lessons/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- PROGRESO ---
    match /progress/{pid} {
      allow read: if isSignedIn()
                  && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create, update: if isSignedIn()
                  && request.resource.data.userId == request.auth.uid
                  && request.resource.data.keys().hasOnly(
                       ['userId', 'lessonId', 'lessonNumber', 'completed', 'completedAt'])
                  && request.resource.data.lessonNumber is int
                  && request.resource.data.completed is bool
                  && request.resource.data.lessonId is string
                  && (request.resource.data.completedAt == null
                      || request.resource.data.completedAt is int);
      allow delete: if isAdmin()
                  || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // --- FORO ---
    match /forumPosts/{pid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.status == 'visible'
                    && request.resource.data.keys().hasOnly(
                         ['lessonNumber', 'userId', 'userName', 'userPhoto', 'message', 'createdAt', 'parentId', 'status'])
                    && request.resource.data.message is string
                    && request.resource.data.message.size() > 0
                    && request.resource.data.message.size() <= 5000
                    && request.resource.data.lessonNumber is int
                    && request.resource.data.createdAt is int
                    && request.resource.data.userName is string
                    && request.resource.data.userName.size() <= 120
                    && (request.resource.data.userPhoto == null
                        || request.resource.data.userPhoto is string)
                    && (request.resource.data.parentId == null
                        || request.resource.data.parentId is string);
      // El autor puede editar/borrar lo suyo (sin cambiar de dueño); el admin todo.
      allow update: if isAdmin()
                    || (isSignedIn()
                        && resource.data.userId == request.auth.uid
                        && request.resource.data.userId == resource.data.userId);
      allow delete: if isAdmin();
    }

    // --- AJUSTES (solo admin escribe) ---
    match /adminSettings/{doc} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- HISTORIAL DE AÑOS (resúmenes de años cerrados; solo admin, contiene datos) ---
    match /cohorts/{id} {
      allow read, write: if isAdmin();
    }
  }
}
